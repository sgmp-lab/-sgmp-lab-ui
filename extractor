    async function buildSegmentedSipocImageData() {
      if (!state.preparedImageData) {
        return "";
      }

      const canvas = await imageDataToCanvas(state.preparedImageData);
      const context = canvas.getContext("2d");

      context.lineWidth = Math.max(2, Math.round(canvas.width * 0.002));
      context.setLineDash([Math.max(6, Math.round(canvas.width * 0.006)), Math.max(5, Math.round(canvas.width * 0.004))]);
      context.strokeStyle = "#00AEEF";
      context.fillStyle = "rgba(0, 194, 255, 0.10)";
      context.font = `${Math.max(14, Math.round(canvas.width * 0.014))}px Arial`;
      context.textBaseline = "top";

      state.segments.forEach(function(segment) {
        const bounds = normalizeBounds(segment.bounds_pct || {});
        const x = (bounds.x / 100) * canvas.width;
        const y = (bounds.y / 100) * canvas.height;
        const width = (bounds.width / 100) * canvas.width;
        const height = (bounds.height / 100) * canvas.height;

        context.fillRect(x, y, width, height);
        context.strokeRect(x, y, width, height);

        const label = segment.segment_id || "SEG";
        const labelPadding = Math.max(5, Math.round(canvas.width * 0.004));
        const metrics = context.measureText(label);
        const labelWidth = metrics.width + labelPadding * 2;
        const labelHeight = Math.max(20, Math.round(canvas.width * 0.024));

        context.setLineDash([]);
        context.fillStyle = "#0B2E59";
        context.fillRect(x, y, labelWidth, labelHeight);
        context.fillStyle = "#FFFFFF";
        context.fillText(label, x + labelPadding, y + labelPadding);
        context.fillStyle = "rgba(0, 194, 255, 0.10)";
        context.setLineDash([Math.max(6, Math.round(canvas.width * 0.006)), Math.max(5, Math.round(canvas.width * 0.004))]);
      });

      return canvas.toDataURL("image/png");
    }

