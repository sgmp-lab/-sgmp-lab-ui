    async function cropSegmentFromPreparedImage(segment) {
      if (!segment || !state.preparedImageData) {
        return "";
      }

      const sourceCanvas = await imageDataToCanvas(state.preparedImageData);
      const bounds = normalizeBounds(segment.bounds_pct || {});
      const padding = Number(state.segmentCropPaddingPct || 1.5);

      const xPct = Math.max(0, bounds.x - padding);
      const yPct = Math.max(0, bounds.y - padding);
      const endXPct = Math.min(100, bounds.x + bounds.width + padding);
      const endYPct = Math.min(100, bounds.y + bounds.height + padding);

      const sx = Math.round((xPct / 100) * sourceCanvas.width);
      const sy = Math.round((yPct / 100) * sourceCanvas.height);
      const sw = Math.max(1, Math.round(((endXPct - xPct) / 100) * sourceCanvas.width));
      const sh = Math.max(1, Math.round(((endYPct - yPct) / 100) * sourceCanvas.height));

      const outputCanvas = document.createElement("canvas");
      const outputContext = outputCanvas.getContext("2d");

      outputCanvas.width = sw;
      outputCanvas.height = sh;
      outputContext.drawImage(sourceCanvas, sx, sy, sw, sh, 0, 0, sw, sh);

      return outputCanvas.toDataURL("image/png");
    }

    async function generateSegmentCrops(showConfirmation) {
      if (!state.preparedImageData) {
        showMsg("segmentationMsg", "warn", "Primero carga y usa una imagen preparada del SIPOC.");
        return;
