    return;
  }

  await loadImageFile(file);
}


    function loadImageFile(file) {
      return new Promise(function(resolve) {
        const reader = new FileReader();

        reader.onload = function(loadEvent) {
          state.sourceImageData = loadEvent.target.result;
          state.preparedImageData = state.sourceImageData;
          renderSourceImage();
          renderPreparedOverlay();
          generateSegmentationPrompt();
          showMsg("sourceMsg", "ok", "Imagen SIPOC cargada y lista para segmentación.");
          resolve();
        };

        reader.readAsDataURL(file);
      });
    }

    function renderSourceImage() {
      const stage = qs("sourceImageStage");

      if (!stage) {
        return;
      }

      if (!state.preparedImageData && !state.sourceImageData) {
        stage.textContent = "Sin imagen cargada";
        return;
      }

      stage.innerHTML = `
        <div class="image-wrap">
          <img src="${state.preparedImageData || state.sourceImageData}" alt="SIPOC fuente" />
        </div>
      `;
    }

    function imageDataToCanvas(dataUrl) {
      return new Promise(function(resolve, reject) {
        const image = new Image();

        image.onload = function() {
          const canvas = document.createElement("canvas");
          const context = canvas.getContext("2d");

          canvas.width = image.naturalWidth;
          canvas.height = image.naturalHeight;
          context.drawImage(image, 0, 0);

          resolve(canvas);
        };

        image.onerror = reject;
        image.src = dataUrl;
      });
    }


    function normalizeBounds(bounds) {
      const data = bounds || {};
      let x = Number(data.x ?? data.x_start_pct ?? data.x_pct ?? 0);
      let y = Number(data.y ?? data.y_start_pct ?? data.y_pct ?? 0);
      let width = Number(data.width ?? data.width_pct ?? 0);
      let height = Number(data.height ?? data.height_pct ?? 0);

      if (!width && typeof data.x_end_pct !== "undefined") {
        width = Number(data.x_end_pct) - x;
      }

      if (!height && typeof data.y_end_pct !== "undefined") {
        height = Number(data.y_end_pct) - y;
      }

      x = Math.max(0, Math.min(100, x));
      y = Math.max(0, Math.min(100, y));
      width = Math.max(0, Math.min(100 - x, width || 10));
      height = Math.max(0, Math.min(100 - y, height || 10));

      return { x, y, width, height };
    }

    function fileSafeName(value) {
      return String(value || "segmento")
        .normalize("NFD")
        .replace(/[̀-ͯ]/g, "")
        .replace(/[^a-z0-9_-]+/gi, "_")
        .replace(/^_+|_+$/g, "")
        .slice(0, 90) || "segmento";
    }

    function downloadDataUrl(dataUrl, filename) {
      if (!dataUrl) {
