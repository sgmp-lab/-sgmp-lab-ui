      state.segments
        .sort(function(a, b) {
          return (a.order || 0) - (b.order || 0);
        })
        .forEach(function(segment) {
          const div = document.createElement("div");
          div.className = "block-item" + (segment.segment_id === state.activeSegmentId ? " active" : "");
