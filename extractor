    function renderSegmentSummary(parsed) {
      const box = qs("segmentSummary");

      if (!parsed) {
        box.textContent = "Sin extracción procesada.";
        return;
      }

      const view = parsed.segment_operational_view || {};
      const activities = Array.isArray(view.activities) ? view.activities : (Array.isArray(parsed.activities_partial) ? parsed.activities_partial : []);
      const inputs = Array.isArray(view.inputs) ? view.inputs : [];
      const outputs = Array.isArray(view.outputs) ? view.outputs : [];
      const notes = Array.isArray(view.notes) ? view.notes : (Array.isArray(parsed.notes_catalog) ? parsed.notes_catalog : []);
      const relations = Array.isArray(view.relations) ? view.relations : (Array.isArray(parsed.flow_logic_partial) ? parsed.flow_logic_partial : []);
      const validation = parsed.validation || parsed.traceability || {};
      const pending = [];

      ["pending_validation", "open_questions", "unresolved_connectors", "visual_uncertainties", "manual_validation_required", "unclear_connections"].forEach(function(key) {
        if (Array.isArray(validation[key])) {
          validation[key].forEach(function(item) {
            pending.push(item);
          });
        }
      });

      const parts = [];
      parts.push(`<h3>Segmento ${esc(parsed.segment_id || "")}</h3>`);

      parts.push(`<h4>Actividades visibles (${activities.length})</h4>`);
      if (activities.length) {
        parts.push(`<ul>${activities.map(function(activity) {
          const name = activity.name || activity.activity_name || "pendiente_validacion";
          const actor = activity.actor || activity.lane || "pendiente_validacion";
          return `<li><strong>${esc(name)}</strong> · quién la hace: ${esc(actor)} · tipo: ${esc(activity.type || activity.gpp_type || "activity")}</li>`;
        }).join("")}</ul>`);
      } else {
        parts.push(`<div class="mini-note">No se identificaron actividades visibles en este segmento.</div>`);
      }

      parts.push(`<h4>Entradas visibles (${inputs.length})</h4>`);
      if (inputs.length) {
        parts.push(`<ul>${inputs.map(function(item) {
          return `<li><strong>${esc(item.input || "pendiente_validacion")}</strong> · tipo: ${esc(item.input_type || item.gpp_symbol_type || "pendiente_validacion")} · entrega: ${esc(item.provided_by || "pendiente_validacion")} · recibe: ${esc(item.received_by || item.related_activity || "pendiente_validacion")} · obs: ${esc(item.observations || "")}</li>`;
        }).join("")}</ul>`);
      } else {
        parts.push(`<div class="mini-note">No se identificaron entradas visibles en este segmento.</div>`);
      }

      parts.push(`<h4>Salidas visibles (${outputs.length})</h4>`);
      if (outputs.length) {
        parts.push(`<ul>${outputs.map(function(item) {
          return `<li><strong>${esc(item.output || "pendiente_validacion")}</strong> · tipo: ${esc(item.output_type || item.gpp_symbol_type || "pendiente_validacion")} · genera: ${esc(item.provided_by || item.related_activity || "pendiente_validacion")} · recibe: ${esc(item.received_by || "pendiente_validacion")} · obs: ${esc(item.observations || "")}</li>`;
        }).join("")}</ul>`);
      } else {
        parts.push(`<div class="mini-note">No se identificaron salidas visibles en este segmento.</div>`);
      }

      if (notes.length) {
        parts.push(`<h4>Notas aclaratorias atadas (${notes.length})</h4>`);
        parts.push(`<ul>${notes.map(function(note) {
          return `<li>${esc(note.text || note.reference || JSON.stringify(note))} · actividad: ${esc(note.related_activity || "pendiente_validacion")}</li>`;
        }).join("")}</ul>`);
      }

      if (relations.length) {
        parts.push(`<h4>Relaciones visibles (${relations.length})</h4>`);
        parts.push(`<ul>${relations.map(function(rel) {
          return `<li>${esc(rel.from || "pendiente_validacion")} → ${esc(rel.to || "pendiente_validacion")} · ${esc(rel.relation_type || rel.logic_type || "")}</li>`;
        }).join("")}</ul>`);
      }

      if (pending.length) {
        parts.push(`<h4>Validación pendiente (${pending.length})</h4>`);
        parts.push(`<ul>${pending.map(function(item) {
          return `<li>${esc(typeof item === "object" ? JSON.stringify(item) : item)}</li>`;
        }).join("")}</ul>`);
      }

      box.innerHTML = parts.join("");
    }

    function mergeArray(target, source) {
      if (!Array.isArray(source)) {
        return;
      }

      source.forEach(function(item) {
        const key = typeof item === "object" ? JSON.stringify(item) : String(item);
        const exists = target.some(function(existing) {
          return (typeof existing === "object" ? JSON.stringify(existing) : String(existing)) === key;
        });

        if (!exists) {
          target.push(item);
        }
      });
    }

    function withSource(item, segment) {
      if (typeof item !== "object" || item === null) {
        return item;
      }

      return Object.assign({}, item, {
        source_segment: {
          id: segment.segment_id,
          title: segment.title,
          type: segment.segment_type
        }
      });
    }

    function cleanText(value) {
      return String(value || "").trim().replace(/\s+/g, " ");
    }

    function cleanKey(value) {
      return cleanText(value)
        .toUpperCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "");
    }

    function pushUniqueText(target, value) {
      const clean = cleanText(value);
      if (!clean || clean === "pendiente_validacion") return;
      const key = cleanKey(clean);
      const exists = target.some(function(item) {
        return cleanKey(item) === key;
      });
      if (!exists) target.push(clean);
    }

    function pushUniqueObject(target, item, keyFields) {
      if (!item || typeof item !== "object") return;
      const key = keyFields.map(function(field) {
        return cleanKey(item[field]);
      }).join("|");
      if (!key.replace(/\|/g, "")) return;
      const exists = target.some(function(existing) {
        return keyFields.map(function(field) {
          return cleanKey(existing[field]);
        }).join("|") === key;
      });
      if (!exists) target.push(item);
    }

    function normalizeList(value) {
      if (!Array.isArray(value)) return [];
      return value.map(cleanText).filter(Boolean);
    }

    function collectOperationalDraft() {
      const draft = {
        catalogs: {
          suppliers: [],
          inputs: [],
          outputs: [],
          customers: [],
          actors: [],
          documents_systems: []
        },
        activities: [],
        decisions: [],
        relations: [],
        notes: [],
        pending_validation: [],
        unresolved_connectors: []
      };

      state.segments.forEach(function(segment) {
        const parsed = segment.parsed;
        if (!parsed) return;

        const view = parsed.segment_operational_view || {};
        const catalogs = parsed.catalogs_partial || {};

        (catalogs.suppliers || []).forEach(function(x) { pushUniqueText(draft.catalogs.suppliers, x); });
        (catalogs.inputs || []).forEach(function(x) { pushUniqueText(draft.catalogs.inputs, x); });
        (catalogs.outputs || []).forEach(function(x) { pushUniqueText(draft.catalogs.outputs, x); });
        (catalogs.customers || []).forEach(function(x) { pushUniqueText(draft.catalogs.customers, x); });
        (catalogs.actors || []).forEach(function(x) { pushUniqueText(draft.catalogs.actors, x); });

        (view.inputs || []).forEach(function(item) {
          pushUniqueText(draft.catalogs.inputs, item.input);
          pushUniqueText(draft.catalogs.suppliers, item.provided_by);
          if (item.received_by && item.received_by !== item.related_activity) pushUniqueText(draft.catalogs.actors, item.received_by);
          if (item.related_activity) {
            pushUniqueObject(draft.relations, {
              from: cleanText(item.input),
              to: cleanText(item.related_activity || item.received_by),
              relation_type: "input_to_activity",
              condition: "",
              connector_label: cleanText(item.connector_label),
              source_segment_id: segment.segment_id,
              confidence: cleanText(item.confidence)
            }, ["from", "to", "relation_type", "connector_label"]);
          }
        });

        (view.outputs || []).forEach(function(item) {
          pushUniqueText(draft.catalogs.outputs, item.output);
          pushUniqueText(draft.catalogs.customers, item.received_by);
          if (item.related_activity || item.provided_by) {
            pushUniqueObject(draft.relations, {
              from: cleanText(item.related_activity || item.provided_by),
              to: cleanText(item.output),
              relation_type: "activity_to_output",
              condition: "",
              connector_label: cleanText(item.connector_label),
              source_segment_id: segment.segment_id,
              confidence: cleanText(item.confidence)
            }, ["from", "to", "relation_type", "connector_label"]);
          }
        });

        (view.activities || parsed.activities_partial || []).forEach(function(activity) {
          const item = {
            id: cleanText(activity.activity_id || activity.id),
            name: cleanText(activity.name || activity.activity_name),
            actor: cleanText(activity.actor || activity.lane),
            type: cleanText(activity.type || activity.gpp_type || "activity"),
            previous: normalizeList(activity.previous),
            next: normalizeList(activity.next),
            inputs_received: Array.isArray(activity.inputs_received) ? activity.inputs_received.map(function(input) {
              return {
                input: cleanText(input.input || input),
                provided_by: cleanText(input.provided_by),
                connector_label: cleanText(input.connector_label),
                confidence: cleanText(input.confidence)
              };
            }).filter(function(x) { return x.input; }) : [],
            outputs_delivered: Array.isArray(activity.outputs_delivered) ? activity.outputs_delivered.map(function(output) {
              return {
                output: cleanText(output.output || output),
                received_by: cleanText(output.received_by),
                connector_label: cleanText(output.connector_label),
                confidence: cleanText(output.confidence)
              };
            }).filter(function(x) { return x.output; }) : [],
            clarification_note_refs: Array.isArray(activity.clarification_note_refs)
              ? activity.clarification_note_refs.map(cleanText).filter(Boolean)
                 : [],
                 observations: cleanText(activity.observations),
            source_segment_id: segment.segment_id
          };

          if (!item.name) return;
          pushUniqueText(draft.catalogs.actors, item.actor);
          item.inputs_received.forEach(function(x) { pushUniqueText(draft.catalogs.inputs, x.input); pushUniqueText(draft.catalogs.suppliers, x.provided_by); });
          item.outputs_delivered.forEach(function(x) { pushUniqueText(draft.catalogs.outputs, x.output); pushUniqueText(draft.catalogs.customers, x.received_by); });

          if (item.type === "decision") {
            pushUniqueObject(draft.decisions, item, ["name", "actor"]);
          } else {
            pushUniqueObject(draft.activities, item, ["name", "actor"]);
          }
        });

        (view.relations || parsed.flow_logic_partial || []).forEach(function(rel) {
          const item = {
            from: cleanText(rel.from),
            to: cleanText(rel.to),
            relation_type: cleanText(rel.relation_type || rel.logic_type),
            condition: cleanText(rel.condition),
            connector_label: cleanText(rel.connector_label),
            source_segment_id: segment.segment_id,
            confidence: cleanText(rel.confidence)
          };
          if (!item.from || !item.to) return;
          if (item.from === "pendiente_validacion" || item.to === "pendiente_validacion" || item.relation_type === "pending_connector" || item.relation_type === "pending_boundary_resolution") {
            pushUniqueObject(draft.unresolved_connectors, item, ["from", "to", "connector_label"]);
          } else {
            pushUniqueObject(draft.relations, item, ["from", "to", "relation_type", "condition", "connector_label"]);
          }
        });

        (view.notes || parsed.notes_catalog || []).forEach(function(note) {
          pushUniqueObject(draft.notes, {
            note_id: cleanText(note.note_id),
            text: cleanText(note.text || note.reference),
            related_activity: cleanText(note.related_activity),
            rule_or_condition: cleanText(note.rule_or_condition || note.note_type),
            source_segment_id: segment.segment_id,
            confidence: cleanText(note.confidence)
          }, ["text", "related_activity"]);
        });

        const validation = parsed.validation || parsed.traceability || {};
        ["pending_validation", "open_questions", "visual_uncertainties", "manual_validation_required", "unclear_connections"].forEach(function(key) {
          if (Array.isArray(validation[key])) {
            validation[key].forEach(function(item) {
              pushUniqueText(draft.pending_validation, typeof item === "object" ? JSON.stringify(item) : item);
            });
          }
        });

        if (Array.isArray(validation.unresolved_connectors)) {
          validation.unresolved_connectors.forEach(function(item) {
            if (typeof item === "object") {
              pushUniqueObject(draft.unresolved_connectors, Object.assign({ source_segment_id: segment.segment_id }, item), ["connector_label", "from", "to"]);
            } else {
              pushUniqueText(draft.pending_validation, item);
            }
          });
        }
      });

      return draft;
    }

    function buildDraftLmpJson() {
      syncPlainTextNotes();
      const draft = collectOperationalDraft();

      return {
        source_type: "existing_process_extractor",
        catalogs: draft.catalogs,
        as_is_flow: {
          activities: draft.activities,
          decisions: draft.decisions,
          relations: draft.relations,
          notes: draft.notes
        },
        manual_plain_text_notes: {
          source: "manual_paste",
          raw_text: state.plainTextNotes || "",
          status: state.plainTextNotes ? "pending_consolidation" : "empty"
        },
        validation: {
          pending_validation: draft.pending_validation,
          duplicates_resolved: [],
          unresolved_connectors: draft.unresolved_connectors
        }
      };
    }

    function buildTraceabilityJson() {
      syncPlainTextNotes();

      return {
        instrument: "sgmp_sipoc_functional_extractor",
        version: "0.9",
        generatedAt: new Date().toISOString(),
        traceability_type: "full_extractor_traceability",
        notes_mode: "manual_plain_text",
        plain_text_notes_present: Boolean(state.plainTextNotes),
        gpp_symbol_types: GPP_SYMBOL_TYPES,
        lane_registry: state.lane_registry,
        column_registry: state.column_registry,
        segmentation_quality: state.segmentation_quality,
        coverage_audit: state.coverage_audit,
        segmentation_plan: state.segmentation_plan,
        segments: state.segments.map(function(segment) {
          return {
            segment_id: segment.segment_id,
            title: segment.title,
            type: segment.segment_type,
            metadata: segmentMetadata(segment),
            has_image: Boolean(segment.imageData),
            cropGeneratedAt: segment.cropGeneratedAt || null,
            processedAt: segment.processedAt || null,
            extraction: segment.parsed || null
          };
        })
      };
    }

    function buildFinalJson() {
      return state.consolidatedLmpJson || buildDraftLmpJson();
    }

    function generateConsolidationPrompt() {
      syncPlainTextNotes();

      const draft = buildDraftLmpJson();

      const consolidationInput = {
        visual_segment_extractions: {
          catalogs: draft.catalogs,
          as_is_flow: draft.as_is_flow,
          validation: draft.validation
        },
        manual_plain_text_notes: state.plainTextNotes || ""
      };

      const promptTemplate = sgmpPrompt("consolidation");
      state.consolidationPrompt = renderPromptTemplate(promptTemplate, {
        consolidation_input_json: JSON.stringify(consolidationInput, null, 2)
      });

      refreshFinalPreview();
      return state.consolidationPrompt;
    }

    function processConsolidatedLmpJson() {
      try {
        const parsed = JSON.parse(stripFence(qs("consolidationJson").value));
        state.consolidationJsonText = qs("consolidationJson").value;
        state.consolidatedLmpJson = parsed;
        refreshFinalPreview();
        showMsg("consolidationMsg", "ok", "JSON compacto LMP procesado.");
      } catch (error) {
        showMsg("consolidationMsg", "err", "JSON inválido: " + error.message);
      }
    }

    function refreshFinalPreview() {
      if (qs("consolidationPrompt")) qs("consolidationPrompt").value = state.consolidationPrompt || "";
      if (qs("consolidationJson")) qs("consolidationJson").value = state.consolidationJsonText || "";
      qs("finalPreview").textContent = JSON.stringify(buildFinalJson(), null, 2);
    }

    function downloadJsonFile(data, filename) {
      const blob = new Blob([JSON.stringify(data, null, 2)], {
        type: "application/json;charset=utf-8"
      });
      const link = document.createElement("a");
      link.href = URL.createObjectURL(blob);
      link.download = filename;
      link.click();
      URL.revokeObjectURL(link.href);
    }

    function exportFinalJson() {
      const code = "sipoc";
      downloadJsonFile(buildFinalJson(), `json_lmp_${code}.json`);
    }

    function exportTraceabilityJson() {
      const code = "sipoc";
      downloadJsonFile(buildTraceabilityJson(), `trazabilidad_extractor_${code}.json`);
    }

    function buildLightState() {
  return {
    segmentCropPaddingPct: state.segmentCropPaddingPct || 1.5,

    lane_registry: state.lane_registry || [],
    column_registry: state.column_registry || [],
    segmentation_quality: state.segmentation_quality || null,
    coverage_audit: state.coverage_audit || null,
    segmentation_plan: state.segmentation_plan || [],

    segments: (state.segments || []).map(function(segment) {
      return {
        segment_id: segment.segment_id,
        segment_type: segment.segment_type,
        title: segment.title,
        order: segment.order,
        bounds_pct: segment.bounds_pct,
        visible_lanes: segment.visible_lanes || [],
        lane_headers_visible: Boolean(segment.lane_headers_visible),
        requires_lane_registry: Boolean(segment.requires_lane_registry),
        boundary_flow_expected: Boolean(segment.boundary_flow_expected),
        cross_lane_flow_expected: Boolean(segment.cross_lane_flow_expected),
        connector_resolution_expected: Boolean(segment.connector_resolution_expected),
        expected_gpp_elements: segment.expected_gpp_elements || [],
        capture_guidance: segment.capture_guidance || "",
        overlap_required: segment.overlap_required || "",
        complexity: segment.complexity || "",
        extraction_focus: segment.extraction_focus || "",
        manual_check_reason: segment.manual_check_reason || "",
        overlap_justification: segment.overlap_justification || "",
        related_segments: segment.related_segments || [],
        coverage_role: segment.coverage_role || "",

        prompt: segment.prompt || "",
        jsonText: segment.jsonText || "",
        parsed: segment.parsed || null,
        processedAt: segment.processedAt || null
      };
    }),

    activeSegmentId: state.activeSegmentId || null,
    plainTextNotes: state.plainTextNotes || "",
    consolidationPrompt: state.consolidationPrompt || "",
    consolidationJsonText: state.consolidationJsonText || "",
    consolidatedLmpJson: state.consolidatedLmpJson || null
  };
}

function buildBackupJson() {
  syncPlainTextNotes();

  return {
    instrument: "sgmp_sipoc_functional_extractor",
    version: "0.9",
    backup_type: "work_session_light",
    generatedAt: new Date().toISOString(),
    state: buildLightState()
  };
}

    function exportBackupJson() {
      const code = "sipoc";
      downloadJsonFile(buildBackupJson(), `respaldo_extractor_${code}.json`);
    }

    function triggerBackupImport() {
      qs("backupImportInput").click();
    }

    function restoreStateFromObject(data) {
      state = data && data.state ? data.state : data;
      state.sourceImageData = state.sourceImageData || "";
      state.preparedImageData = state.preparedImageData || state.sourceImageData || "";
      state.segmentCropPaddingPct = state.segmentCropPaddingPct || 1.5;
      state.lane_registry = state.lane_registry || [];
      state.column_registry = state.column_registry || [];
      state.segmentation_plan = state.segmentation_plan || [];
      state.segments = state.segments || [];
      state.activeSegmentId = state.activeSegmentId || null;
      state.plainTextNotes = state.plainTextNotes || "";
      state.consolidationPrompt = state.consolidationPrompt || "";
      state.consolidationJsonText = state.consolidationJsonText || "";
      state.consolidatedLmpJson = state.consolidatedLmpJson || null;

      const notesBox = qs("plainTextNotes");
      if (notesBox) notesBox.value = state.plainTextNotes;

      renderSourceImage();
renderSegmentList();
renderPreparedOverlay();
renderSegmentWork();
refreshFinalPreview();

if (state.segments.length && !state.preparedImageData) {
  alert(
    "Respaldo cargado. Vuelve a cargar la imagen SIPOC para regenerar los recortes desde la segmentación guardada."
  );
}
    }

    function importBackupJson(event) {
      const file = event.target.files && event.target.files[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = function() {
        try {
          const data = JSON.parse(reader.result);
          restoreStateFromObject(data);
          alert("Respaldo JSON cargado.");
        } catch (error) {
          alert("No se pudo cargar el respaldo: " + error.message);
        } finally {
          event.target.value = "";
        }
      };
      reader.readAsText(file, "utf-8");
    }

    async function copyText(id, message) {
      const element = qs(id);
      const text = element.value || element.textContent || "";

      if (!text.trim()) {
        return;
      }

      await navigator.clipboard.writeText(text);
      alert(message || "Copiado.");
    }

    function saveSession() {
  syncPlainTextNotes();

  try {
    localStorage.setItem(
      "sgmp_sipoc_extractor_session",
      JSON.stringify(buildBackupJson())
    );

    alert("Sesión local guardada. Las imágenes y recortes no se guardan para evitar sobrecargar el navegador.");
  } catch (error) {
    console.warn("No se pudo guardar la sesión local:", error);

    alert(
      "No se pudo guardar la sesión local porque el navegador alcanzó el límite de almacenamiento. " +
      "Descarga un respaldo JSON liviano para conservar el avance."
    );
  }
}

    function loadSession() {
      const raw =
        localStorage.getItem("sgmp_sipoc_extractor_session") ||
        localStorage.getItem("sgmp_sipoc_extractor_legacy_08") ||
        localStorage.getItem("sgmp_sipoc_extractor_legacy_07") ||
        localStorage.getItem("sgmp_sipoc_extractor_legacy_05");

      if (!raw) {
        alert("No hay sesión local guardada.");
        return;
      }

      try {
        restoreStateFromObject(JSON.parse(raw));
        alert("Sesión local cargada.");
      } catch (error) {
        alert("No se pudo cargar sesión local: " + error.message);
      }
    }


    // ════════════════════════════════════════════════════════════════
    // SGMP · API automática + fallback manual
    // ════════════════════════════════════════════════════════════════

    function openLmpModule() {
      if (!LMP_MODULE_URL || LMP_MODULE_URL.indexOf("PEGA_AQUI") === 0) {
        alert("Configura primero LMP_MODULE_URL en el HTML o desde el Admin SGMP.");
        return;
      }
      window.open(LMP_MODULE_URL, "_blank");
    }

    function sgmpApiConfigured() {
      return SGMP_API_URL && SGMP_API_URL.indexOf("PEGA_AQUI") !== 0;
    }

    function setAiStatus(mode, message, detail) {
      const box = qs("sgmpAiStatus");
      if (!box) return;

      if (!message) {
        box.className = "sgmp-ai-status";
        box.innerHTML = "";
        return;
      }

      const loader = mode === "processing"
        ? '<div class="sgmp-ai-loader"><span></span></div>'
        : "";

      const manualHint = mode === "manual"
        ? '<div class="sgmp-manual-hint show">Modo manual activo: copia el prompt generado, ejecútalo en el chat de IA, pega la respuesta JSON en el campo correspondiente y continúa.</div>'
        : "";

      box.className = "sgmp-ai-status show";
      box.innerHTML = `<strong>${esc(message)}</strong>${detail ? `<div>${esc(detail)}</div>` : ""}${loader}${manualHint}`;
    }

    function setManualFallback(stageKey, reason) {
      setAiStatus(
        "manual",
        "No se pudo completar la conexión automática con IA.",
        reason || "Continúa con el flujo manual copiar/pegar."
      );
    }

    async function sgmpFetch(action, params) {
      if (!sgmpApiConfigured()) {
        throw new Error("SGMP_API_URL no está configurada.");
      }

      const url = new URL(SGMP_API_URL);
      url.searchParams.set("action", action);
      Object.entries(params || {}).forEach(([key, value]) => {
        url.searchParams.set(key, typeof value === "string" ? value : JSON.stringify(value));
      });

      const response = await fetch(url.toString(), { method: "GET" });
      const data = await response.json();

      if (!data || data.ok === false) {
        throw new Error((data && (data.error || data.message)) || "Respuesta inválida del backend SGMP.");
      }

      return data.data !== undefined ? data.data : data;
    }

    async function loadSgmpConfiguration() {
      if (!sgmpApiConfigured()) {
        setManualFallback("", "Configura SGMP_API_URL para activar ejecución automática.");
        return;
      }

      try {
        setAiStatus("processing", "Conectando con SGMP...", "Cargando prompts y reglas de ejecución del módulo Extractor SIPOC.");

        const prompts = await sgmpFetch("get_prompts", { module_code: SGMP_MODULE_CODE });
        (prompts || []).forEach(function(item) {
          if (item.prompt_key) SGMP_PROMPTS[item.prompt_key] = item.prompt_text || "";
        });

        for (const key of Object.keys(SGMP_STAGE_CODES)) {
          try {
            SGMP_EXECUTION[key] = await sgmpFetch("get_execution_mode", {
              module_code: SGMP_MODULE_CODE,
              stage_code: SGMP_STAGE_CODES[key]
            });
          } catch (err) {
            SGMP_EXECUTION[key] = {};
          }
        }

        generateSegmentationPrompt();
        setAiStatus("ok", "Configuración SGMP cargada.", "El extractor usará API automática cuando la etapa esté habilitada.");
        setTimeout(() => setAiStatus("", ""), 1800);
      } catch (error) {
        setManualFallback("", error.message);
      }
    }

    function sgmpPrompt(stageKey) {
      const promptKey = SGMP_PROMPT_KEYS[stageKey];
      const prompt = SGMP_PROMPTS[promptKey];

      if (!prompt) {
        return [
          "PROMPT NO CARGADO DESDE SGMP.",
          "Revisa la hoja PROMPTS para el módulo " + SGMP_MODULE_CODE + " y el prompt_key " + promptKey + ".",
          "El sistema entra en modo manual hasta que el prompt esté disponible."
        ].join("\n");
      }

      return prompt;
    }

    function renderPromptTemplate(template, vars) {
      let out = String(template || "");
      Object.entries(vars || {}).forEach(([key, value]) => {
        const re = new RegExp("\\{\\{" + key + "\\}\\}", "g");
        out = out.replace(re, String(value ?? ""));
      });
      return out;
    }

    function sgmpStageUseApi(stageKey) {
      const cfg = SGMP_EXECUTION[stageKey] || {};
      const enabled = String(cfg.enabled || "SI").toUpperCase();
      const useApi = String(cfg.use_api || cfg.useApi || cfg.api_enabled || cfg.apiEnabled || "SI").toUpperCase();
      const mode = String(cfg.execution_mode || cfg.executionMode || "HYBRID").toUpperCase();

      if (enabled === "NO") return false;
      if (mode === "MANUAL" || mode === "MANUAL_SYSTEM") return false;
      return useApi !== "NO";
    }

    async function sgmpCallAI(stageKey, prompt, imageData) {
      if (!sgmpStageUseApi(stageKey)) {
        throw new Error("La etapa está configurada en modo manual.");
      }

      const payload = {
        action: "call_ai",
        module_code: SGMP_MODULE_CODE,
        stage_code: SGMP_STAGE_CODES[stageKey],
        prompt: prompt || "",
        // La imagen se envía internamente al backend. No se muestra ni se exporta como base64.
        image_data: imageData || ""
      };

      const response = await fetch(SGMP_API_URL, {
        method: "POST",
        body: JSON.stringify(payload),
        headers: { "Content-Type": "text/plain;charset=utf-8" }
      });

      const data = await response.json();
      if (!data || data.ok === false) {
        throw new Error((data && (data.error || data.message)) || "Error en ejecución IA.");
      }

      return data.text || data.result || data.content || (data.data && (data.data.text || data.data.result || data.data.content)) || JSON.stringify(data.data || data);
    }

    async function runSegmentationAI() {
      try {
        if (!state.preparedImageData) {
          showMsg("segmentationMsg", "warn", "Primero carga la imagen SIPOC.");
          return;
        }

        const prompt = generateSegmentationPrompt();
        setAiStatus("processing", "Procesando segmentación con IA...", "La respuesta se cargará automáticamente si la conexión finaliza correctamente.");

        const resultText = await sgmpCallAI("segmentation", prompt, state.preparedImageData);
        qs("segmentationJson").value = resultText;
        await applySegmentationJson();

        setAiStatus("ok", "Segmentación completada.", "La respuesta IA fue aplicada automáticamente.");
        setTimeout(() => setAiStatus("", ""), 1800);
      } catch (error) {
        generateSegmentationPrompt();
        setManualFallback("segmentation", error.message);
        showMsg("segmentationMsg", "warn", "Se activó modo manual: copia el prompt, procesa la imagen en el chat IA y pega el JSON.");
      }
    }

    async function runSegmentExtractionAI() {
      try {
        const segment = activeSegment();
        if (!segment) {
          showMsg("extractionMsg", "warn", "Selecciona primero un segmento.");
          return;
        }

        if (!segment.imageData) {
          await generateActiveSegmentCrop();
        }

        const prompt = generateExtractionPrompt();
        setAiStatus("processing", "Procesando segmento con IA...", "La respuesta se cargará automáticamente en el JSON del segmento.");

        const resultText = await sgmpCallAI("extraction", prompt, segment.imageData || "");
        qs("extractionJson").value = resultText;
        processExtractionJson();

        setAiStatus("ok", "Extracción del segmento completada.", "El JSON fue procesado automáticamente.");
        setTimeout(() => setAiStatus("", ""), 1800);
      } catch (error) {
        generateExtractionPrompt();
        setManualFallback("extraction", error.message);
        showMsg("extractionMsg", "warn", "Se activó modo manual: copia el prompt, usa el recorte del segmento y pega el JSON.");
      }
    }

    async function runConsolidationAI() {
      try {
        const prompt = generateConsolidationPrompt();
        setAiStatus("processing", "Consolidando JSON LMP con IA...", "La respuesta se cargará automáticamente en el campo JSON compacto LMP.");

        const resultText = await sgmpCallAI("consolidation", prompt, "");
        qs("consolidationJson").value = resultText;
        processConsolidatedLmpJson();

        setAiStatus("ok", "Consolidación completada.", "El JSON para LMP quedó procesado automáticamente.");
        setTimeout(() => setAiStatus("", ""), 1800);
      } catch (error) {
        generateConsolidationPrompt();
        setManualFallback("consolidation", error.message);
        showMsg("consolidationMsg", "warn", "Se activó modo manual: copia el prompt de consolidación y pega el JSON.");
      }
    }



    fillContext();
    loadSgmpConfiguration();
    generateSegmentationPrompt();
    renderSourceImage();
    renderSegmentList();
    renderPreparedOverlay();
    renderSegmentWork();
    refreshFinalPreview();

    </script>
</body>
