    async function trimSourceMargins() {
      const dataUrl = state.preparedImageData || state.sourceImageData;

      if (!dataUrl) {
        showMsg("sourceMsg", "warn", "Primero carga una imagen.");
        return;
      }

      const canvas = await imageDataToCanvas(dataUrl);
      const context = canvas.getContext("2d");
      const imageData = context.getImageData(0, 0, canvas.width, canvas.height);
      const data = imageData.data;
      const threshold = 245;
      let minX = canvas.width;
      let minY = canvas.height;
      let maxX = 0;
      let maxY = 0;

      for (let y = 0; y < canvas.height; y += 1) {
        for (let x = 0; x < canvas.width; x += 1) {
          const index = (y * canvas.width + x) * 4;
          const r = data[index];
          const g = data[index + 1];
          const b = data[index + 2];
          const alpha = data[index + 3];
          const isWhite = r > threshold && g > threshold && b > threshold;

          if (alpha > 0 && !isWhite) {
            minX = Math.min(minX, x);
            minY = Math.min(minY, y);
            maxX = Math.max(maxX, x);
            maxY = Math.max(maxY, y);
          }
        }
      }

      if (minX >= maxX || minY >= maxY) {
        showMsg("sourceMsg", "warn", "No se detectaron márgenes blancos de forma confiable.");
        return;
      }

      const padding = 16;
      minX = Math.max(0, minX - padding);
      minY = Math.max(0, minY - padding);
      maxX = Math.min(canvas.width, maxX + padding);
      maxY = Math.min(canvas.height, maxY + padding);

      const outputCanvas = document.createElement("canvas");
      const outputContext = outputCanvas.getContext("2d");
      const width = maxX - minX;
      const height = maxY - minY;

      outputCanvas.width = width;
      outputCanvas.height = height;
      outputContext.drawImage(canvas, minX, minY, width, height, 0, 0, width, height);

      state.preparedImageData = outputCanvas.toDataURL("image/png");
      renderSourceImage();
      renderPreparedOverlay();
      showMsg("sourceMsg", "ok", "Márgenes recortados. Usa esta imagen preparada para segmentar.");
    }

    function useSourceForSegmentation() {
